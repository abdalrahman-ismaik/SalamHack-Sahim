# Frontend environment variables — NEVER commit .env.local to git
# Copy this file to .env.local and update the value.
#
# Must match where uvicorn listens (localhost vs 127.0.0.1 are different URLs in the browser).
# Search and all API calls use: NEXT_PUBLIC_API_URL + /api/...
# Local uvicorn is HTTP only — use http:// not https:// or fetch will fail.
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
