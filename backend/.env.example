# sSsahim Backend — Required Environment Variables
# Copy to .env and fill in real values. NEVER commit .env to git.

# --- Financial Data APIs ---
TWELVE_DATA_API_KEY=your_twelve_data_api_key_here
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here

# --- AI / News APIs ---
# Gemini free tier: 1,500 req/day — get key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
# Groq API key (optional alternative to Gemini): https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
NEWSAPI_KEY=your_newsapi_key_here

# --- Halal Screening ---
MUSAFFA_API_KEY=your_musaffa_api_key_here

# --- CORS ---
# Comma-separated list of allowed frontend origins (must match the browser URL exactly).
# Include every dev URL you use, e.g. both localhost and 127.0.0.1 and ports 3000/3001.
# Example: http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:3001
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:3001
